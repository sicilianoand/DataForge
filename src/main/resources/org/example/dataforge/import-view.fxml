<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<StackPane alignment="TOP_LEFT" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity"
           prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/17.0.12"
           xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.dataforge.controller.ImportController"
           fx:id="rootPane">
    <VBox alignment="CENTER" prefHeight="200.0" prefWidth="100.0" style="-fx-spacing: 15;">
        <Label id="dropLabel" alignment="CENTER" contentDisplay="TEXT_ONLY" text="Trascina il file qui"
               textOverrun="CLIP">
            <font>
                <Font name="System Bold" size="18.0"/>
            </font>
        </Label>
        <Label text="oppure">
            <font>
                <Font size="14.0"/>
            </font>
        </Label>
        <Button fx:id="browseButton" mnemonicParsing="false" onAction="#onBrowse" text="Sfoglia">
            <font>
                <Font name="System Bold" size="18.0"/>
            </font>
        </Button>
    </VBox>
</StackPane>
